Algoritmo  ejemplo
	definir a,b,c,d Como entero 
	definir suma,resta,potencia Como Entero
	escribir "Ingrese a: "
	leer a
	escribir "Ingrese b: "
	leer b
	escribir "Ingrese c: "
	leer c
	escribir "Ingrese d: "
	leer d
	//paso 1: Sumar a+b 
	suma=a+b 
	//paso 2: restar 4
	resta=suma-4
	//paso 3: elevar al cuadrado
	potencia=resta^2 
	//paso 4: dividir entre c*d
	resultado=potencia/(c*d)
	escribir "El resultado es: ", resultado 
	
FinAlgoritmo


	
	

