Algoritmo entrevista
	definir a,b,c Como Entero
	escribir "Ingrese la dedad de heidy:"
	leer a 
	escribir "Ingrese la edad de julian:"
	leer b 
	escribir "Ingrese la edad de kevin:"
	leer c 
	si a >= 20 o heidy >= 20 o julian >=20 o kevin >=20 Entonces
		escribir "Usted puede votar "
	sino 
		escribir "Vaya para la casa"
	FinSi
	
FinAlgoritmo


	
	
	

	

